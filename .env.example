# Copy this file to .env.local and fill in your Supabase project values.
# Find these at: https://supabase.com/dashboard/project/<your-ref>/settings/api

# Public values (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only — DO NOT expose to the browser. Used by API routes for writes.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Optional override (defaults to "product-images")
# SUPABASE_STORAGE_BUCKET=product-images
